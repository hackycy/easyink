# Copy this file to .env.local, .env.development, or .env.development.local.
# Real .env files are ignored by git. Environment variables from the shell win over file values.

EASYINK_RENDER_API_HOST=127.0.0.1
EASYINK_RENDER_API_PORT=18081
EASYINK_RENDER_API_CLI_TIMEOUT_MS=120000
EASYINK_RENDER_API_MAX_BODY_BYTES=67108864
EASYINK_RENDER_API_KEEP_WORK_DIR=false
EASYINK_RENDER_API_CORS_ORIGIN=*

# Optional Render CLI path. Leave empty to use local auto-discovery or PATH.
# EASYINK_RENDER_BIN=/absolute/path/to/easyink-render

# Optional default Render runtime. Per-request runtime values still override these.
EASYINK_RENDER_NO_DAEMON=false
EASYINK_RENDER_FORCE_RESTART_DAEMON=false
EASYINK_RENDER_DISABLE_SANDBOX=false
# EASYINK_RENDER_BROWSER_PATH=/absolute/path/to/chromium
# EASYINK_RENDER_HEADLESS_MODE=new
# EASYINK_RENDER_PROFILE_ROOT=/tmp/easyink-render-profile
# EASYINK_RENDER_TEMP_DIR=/tmp/easyink-render-temp
# EASYINK_RENDER_LOG_DIR=/tmp/easyink-render-logs
# EASYINK_RENDER_MAX_CONCURRENCY=2
# EASYINK_RENDER_MAX_QUEUE_SIZE=32
# EASYINK_RENDER_REQUEST_TIMEOUT_MS=30000
# EASYINK_RENDER_IDLE_TIMEOUT_MS=60000
