{
  "name": "@easyink/ui",
  "type": "module",
  "version": "0.0.24",
  "description": "UI components for EasyInk designer workbench",
  "author": "hackycy <hackycy@outlook.com>",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json",
    "./index.css": "./dist/index.css"
  },
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "vue-tsc --noEmit"
  },
  "peerDependencies": {
    "vue": "catalog:framework"
  },
  "dependencies": {
    "@codemirror/commands": "catalog:framework",
    "@codemirror/lang-html": "catalog:framework",
    "@codemirror/lang-javascript": "catalog:framework",
    "@codemirror/lang-json": "catalog:framework",
    "@codemirror/language": "catalog:framework",
    "@codemirror/state": "catalog:framework",
    "@codemirror/view": "catalog:framework",
    "@easyink/icons": "workspace:*",
    "@easyink/shared": "workspace:*",
    "@lezer/highlight": "catalog:framework"
  }
}
