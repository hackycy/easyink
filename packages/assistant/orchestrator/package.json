{
  "name": "@easyink/assistant-orchestrator",
  "type": "module",
  "version": "0.0.24",
  "description": "LangGraph and Hono based orchestration service for EasyInk Assistant",
  "author": "hackycy <hackycy@outlook.com>",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "exports": {
    ".": "./dist/index.mjs",
    "./bin/server": "./dist/bin/server.mjs",
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.mts",
  "bin": {
    "assistant-orchestrator": "./dist/bin/server.mjs"
  },
  "files": [
    ".env.sample",
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "dev:server": "tsx src/bin/server.ts",
    "start": "node dist/bin/server.mjs",
    "test": "vitest run src/**/*.test.ts"
  },
  "dependencies": {
    "@easyink/assistant-adapters": "workspace:*",
    "@easyink/assistant-capabilities": "workspace:*",
    "@easyink/assistant-constraint-engine": "workspace:*",
    "@easyink/assistant-llm": "workspace:*",
    "@easyink/assistant-material-knowledge": "workspace:*",
    "@easyink/assistant-plugins": "workspace:*",
    "@easyink/assistant-scenario-templates": "workspace:*",
    "@easyink/assistant-schema-builder": "workspace:*",
    "@easyink/assistant-store": "workspace:*",
    "@easyink/assistant-tool-registry": "workspace:*",
    "@easyink/assistant-type-aligner": "workspace:*",
    "@easyink/schema": "workspace:*",
    "@easyink/schema-tools": "workspace:*",
    "@hono/node-server": "catalog:framework",
    "@langchain/core": "catalog:framework",
    "@langchain/langgraph": "catalog:framework",
    "dotenv": "catalog:framework",
    "hono": "catalog:framework",
    "pino": "catalog:framework",
    "zod": "catalog:framework"
  }
}
