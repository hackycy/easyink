# Copy this file to packages/assistant/orchestrator/.env or .env.local before local development.
# Existing shell variables and Docker-injected environment variables win over file values.
# .env and .env.* are gitignored; keep secrets out of git.
# Docker Compose reads this package-local file through env_file; do not put these values in the repository root .env.

# HTTP server binding.
EASYINK_ASSISTANT_HTTP_HOST=0.0.0.0
EASYINK_ASSISTANT_HTTP_PORT=3010
EASYINK_ASSISTANT_CORS_ORIGIN=*

# Optional persistence. Leave dir/path empty to use in-memory storage.
# Supported kinds: sqlite | file | memory.
# Docker Compose overrides dir to /var/lib/easyink-assistant and persists it with a named volume.
EASYINK_ASSISTANT_STORE_KIND=sqlite
EASYINK_ASSISTANT_STORE_DIR=.easyink-assistant
EASYINK_ASSISTANT_STORE_SQLITE_FILE=assistant-store.sqlite
# EASYINK_ASSISTANT_STORE_SQLITE_PATH=
# Legacy JSON file store:
# EASYINK_ASSISTANT_STORE_KIND=file
# EASYINK_ASSISTANT_STORE_FILE=assistant-store.json

# LLM provider: openai | openai-compatible | anthropic
# Leave empty to use the deterministic local capability path.
EASYINK_ASSISTANT_LLM_PROVIDER=
EASYINK_ASSISTANT_LLM_MODEL=

# OpenAI / OpenAI-compatible.
OPENAI_API_KEY=
OPENAI_BASE_URL=
EASYINK_ASSISTANT_LLM_BASE_URL=

# Anthropic.
ANTHROPIC_API_KEY=

# Optional request-scoped LLM configuration forwarding.
# Keep disabled for private deployments that only use server-side LLM env above.
# Enable for public/open-source demos where visitors provide their own API key in the browser.
# Runtime credentials are accepted per request and are not stored by the orchestrator.
EASYINK_ASSISTANT_REQUEST_LLM_CONFIG=0
# EASYINK_ASSISTANT_REQUEST_LLM_PROVIDERS=openai,openai-compatible,anthropic
# EASYINK_ASSISTANT_REQUEST_LLM_CUSTOM_BASE_URL=1
# EASYINK_ASSISTANT_REQUEST_LLM_ALLOWED_BASE_URLS=https://api.openai.com,https://api.deepseek.com
# Allow localhost/private-network or http base URLs only when you intentionally support local models.
# EASYINK_ASSISTANT_REQUEST_LLM_PRIVATE_BASE_URL=0
# EASYINK_ASSISTANT_REQUEST_LLM_INSECURE_BASE_URL=0
