# Copy this file to packages/assistant/orchestrator/.env or .env.local before local development.
# Existing shell variables and Docker-injected environment variables win over file values.
# .env and .env.* are gitignored; keep secrets out of git.
# Docker Compose reads this package-local file through env_file; do not put these values in the repository root .env.

# HTTP server binding.
EASYINK_ASSISTANT_HTTP_HOST=0.0.0.0
EASYINK_ASSISTANT_HTTP_PORT=3010
EASYINK_ASSISTANT_CORS_ORIGIN=*

# Optional file persistence. Leave empty to use in-memory storage.
# Docker Compose overrides this to /var/lib/easyink-assistant and persists it with a named volume.
EASYINK_ASSISTANT_STORE_DIR=.easyink-assistant
EASYINK_ASSISTANT_STORE_FILE=assistant-store.json

# LLM provider: openai | openai-compatible | anthropic
# Leave empty to use the deterministic local capability path.
EASYINK_ASSISTANT_LLM_PROVIDER=
EASYINK_ASSISTANT_LLM_MODEL=

# OpenAI / OpenAI-compatible.
OPENAI_API_KEY=
OPENAI_BASE_URL=
EASYINK_ASSISTANT_LLM_BASE_URL=

# Anthropic.
ANTHROPIC_API_KEY=
