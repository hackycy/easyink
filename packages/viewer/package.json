{
  "name": "@easyink/viewer",
  "type": "module",
  "version": "0.0.30",
  "description": "Viewer runtime for EasyInk: preview, print, export",
  "author": "hackycy <hackycy@outlook.com>",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch"
  },
  "dependencies": {
    "@easyink/browser-dom": "workspace:*",
    "@easyink/core": "workspace:*",
    "@easyink/schema": "workspace:*",
    "@easyink/shared": "workspace:*"
  },
  "devDependencies": {
    "@easyink/builtin": "workspace:*"
  }
}
