{
  "name": "@easyink/export-plugin-dom-pdf",
  "type": "module",
  "version": "0.0.14",
  "description": "DOM-to-PDF export plugin for @easyink/export-runtime (html2canvas + jsPDF)",
  "author": "hackycy <hackycy@outlook.com>",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch"
  },
  "dependencies": {
    "@easyink/export-runtime": "workspace:*",
    "@easyink/shared": "workspace:*",
    "html2canvas": "^1.4.1",
    "jspdf": "^2.5.2"
  }
}
