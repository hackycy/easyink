{
  "name": "@easyink/export-plugin-dom-image",
  "type": "module",
  "version": "0.0.29",
  "description": "DOM-to-image export plugin for @easyink/export-runtime (html2canvas)",
  "author": "hackycy <hackycy@outlook.com>",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch"
  },
  "dependencies": {
    "@easyink/export-dom-capture": "workspace:*",
    "@easyink/export-runtime": "workspace:*",
    "html2canvas": "catalog:framework"
  }
}
