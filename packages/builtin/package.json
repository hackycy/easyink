{
  "name": "@easyink/builtin",
  "type": "module",
  "version": "0.0.30",
  "description": "Internal built-in material registry for EasyInk runtimes",
  "author": "hackycy <hackycy@outlook.com>",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./all": {
      "types": "./dist/all.d.mts",
      "import": "./dist/all.mjs"
    },
    "./basic": {
      "types": "./dist/basic.d.mts",
      "import": "./dist/basic.mjs"
    },
    "./none": {
      "types": "./dist/none.d.mts",
      "import": "./dist/none.mjs"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch"
  },
  "dependencies": {
    "@easyink/core": "workspace:*",
    "@easyink/material-barcode": "workspace:*",
    "@easyink/material-chart-bar": "workspace:*",
    "@easyink/material-chart-custom": "workspace:*",
    "@easyink/material-chart-gauge": "workspace:*",
    "@easyink/material-chart-line": "workspace:*",
    "@easyink/material-chart-pie": "workspace:*",
    "@easyink/material-chart-radar": "workspace:*",
    "@easyink/material-chart-scatter": "workspace:*",
    "@easyink/material-ellipse": "workspace:*",
    "@easyink/material-flow-row": "workspace:*",
    "@easyink/material-image": "workspace:*",
    "@easyink/material-line": "workspace:*",
    "@easyink/material-page-number": "workspace:*",
    "@easyink/material-progress": "workspace:*",
    "@easyink/material-qrcode": "workspace:*",
    "@easyink/material-rating": "workspace:*",
    "@easyink/material-rect": "workspace:*",
    "@easyink/material-ring-progress": "workspace:*",
    "@easyink/material-signature": "workspace:*",
    "@easyink/material-svg-custom": "workspace:*",
    "@easyink/material-svg-heart": "workspace:*",
    "@easyink/material-svg-star": "workspace:*",
    "@easyink/material-table-data": "workspace:*",
    "@easyink/material-table-kernel": "workspace:*",
    "@easyink/material-table-static": "workspace:*",
    "@easyink/material-text": "workspace:*",
    "@easyink/schema": "workspace:*",
    "@easyink/shared": "workspace:*"
  },
  "devDependencies": {
    "@easyink/browser-dom": "workspace:*",
    "@easyink/core": "workspace:*",
    "tsx": "catalog:cli"
  }
}
