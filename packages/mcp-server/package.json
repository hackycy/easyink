{
  "name": "@easyink/mcp-server",
  "type": "module",
  "version": "0.0.3",
  "description": "MCP server for EasyInk template generation via LLM",
  "author": "hackycy <hackycy@outlook.com>",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "exports": {
    ".": "./dist/index.mjs",
    "./bin/server": "./dist/bin/server.mjs",
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.mts",
  "bin": {
    "easyink-mcp-server": "./dist/bin/server.mjs"
  },
  "files": [
    "config",
    "dist"
  ],
  "scripts": {
    "build:materials": "tsx scripts/generate-materials-config.ts",
    "check:materials": "tsx scripts/generate-materials-config.ts --check",
    "prebuild": "pnpm build:materials",
    "build": "tsdown",
    "dev": "tsdown --watch",
    "start:stdio": "tsx src/bin/server.ts",
    "start:http": "MCP_TRANSPORT=http tsx src/bin/server.ts",
    "test:local": "tsx scripts/test-local.ts"
  },
  "dependencies": {
    "@easyink/datasource": "workspace:*",
    "@easyink/schema": "workspace:*",
    "@easyink/schema-tools": "workspace:*",
    "@easyink/shared": "workspace:*",
    "@modelcontextprotocol/sdk": "catalog:framework",
    "dotenv": "catalog:framework",
    "zod": "catalog:framework"
  },
  "optionalDependencies": {
    "@anthropic-ai/sdk": "catalog:framework",
    "openai": "catalog:framework"
  },
  "devDependencies": {
    "@types/node": "catalog:types",
    "tsdown": "catalog:cli",
    "tsx": "catalog:cli"
  }
}
