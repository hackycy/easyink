# Copy this file to .env or .env.local before local development.
# Existing shell variables and Docker-injected environment variables win over these values.
# For Docker deployment, prefer docker-compose environment or --env-file instead of baking .env into the image.

# LLM provider: claude | openai
MCP_PROVIDER=claude

# Optional fallback: provider API key. HTTP clients can also send
# X-EasyInk-Provider-Key per request.
MCP_API_KEY=

# Optional: override the provider default model.
# Claude default: claude-sonnet-4-6
# OpenAI default: gpt-4o
MCP_MODEL=

# Optional: custom API base URL for proxy / gateway / compatible endpoints.
# Leave empty to use the provider default endpoint.
MCP_BASE_URL=

# Transport: stdio for local MCP clients, http for standalone server mode.
MCP_TRANSPORT=stdio

# Only used when MCP_TRANSPORT=http.
# Defaults to 0.0.0.0 for Docker/public deployment.
MCP_HTTP_HOST=
MCP_HTTP_PORT=3000
