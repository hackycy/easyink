{
  "name": "@easyink/prop-schemas",
  "type": "module",
  "version": "0.0.16",
  "description": "Built-in material property schemas for EasyInk Designer",
  "author": "hackycy <hackycy@outlook.com>",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@easyink/core": "workspace:*"
  }
}
