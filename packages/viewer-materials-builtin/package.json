{
  "name": "@easyink/viewer-materials-builtin",
  "type": "module",
  "version": "0.0.0",
  "description": "Built-in material bundle for EasyInk Viewer",
  "author": "hackycy <hackycy@outlook.com>",
  "license": "MIT",
  "sideEffects": false,
  "exports": {
